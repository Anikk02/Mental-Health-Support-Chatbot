# -----------------------------
# GENERAL BACKEND SETTINGS
# -----------------------------

APP_ENV=production
DEBUG=false

# -----------------------------
# MONGO DATABASE
# -----------------------------
MONGO_URI=mongodb://localhost:27017
MONGO_DB=mentalchat

# Collections
USERS_COLLECTION=users
CHAT_HISTORY_COLLECTION=chats
MOOD_STATS_COLLECTION=mood_stats
RESPONSE_ANALYSIS_COLLECTION=response_analysis
AUTH_TEMP_COLLECTION=auth_temp
RATE_LIMIT_COLLECTION=rate_limits

# -----------------------------
# JWT & AUTH
# -----------------------------
JWT_SECRET_KEY=CHANGE_THIS_SECRET_IN_PRODUCTION
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# EMAIL (if using SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@mentalchat.local

# -----------------------------
# FRONTEND BASE URL
# -----------------------------
FRONTEND_BASE=http://localhost:3000

# -----------------------------
# MODEL LOADING
# -----------------------------
MODEL_PATH=./trained-mentalchat-model
CLASSIFIER_MODEL=distilbert-base-uncased-finetuned-sst-2-english
USE_CUDA=auto
